<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!-- Search Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔍 Katılımcı Doğrulama"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp" />
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kullanıcı ID ile katılımcı bilgilerini görüntüleyin"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp" />

    <!-- Section Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kullanıcı ID:"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etSearchUserId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Kullanıcı ID'si giriniz"
            android:inputType="number"
            android:padding="16dp"
            android:background="@android:drawable/edit_text"
            android:textSize="16sp"
            android:layout_marginEnd="12dp"
            android:minHeight="56dp"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnVerify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Doğrula"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:minHeight="56dp"
            android:backgroundTint="#1976D2"
            android:elevation="4dp" />

    </LinearLayout>

    <!-- Result Section -->
    <LinearLayout
        android:id="@+id/resultLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp"
        android:background="#FAFAFA"
        android:elevation="2dp"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <!-- Profile Photo -->
        <ImageView
            android:id="@+id/imageViewParticipantPhoto"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="20dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Katılımcı fotoğrafı"
            android:elevation="4dp" />

        <!-- Participant Name -->
        <TextView
            android:id="@+id/tvParticipantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="10dp"
            android:text="İsim" />

        <!-- Participant Title -->
        <TextView
            android:id="@+id/tvParticipantTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"
            android:text="Unvan" />

    </LinearLayout>

    <!-- Error Message -->
    <TextView
        android:id="@+id/tvErrorMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:padding="20dp"
        android:gravity="center"
        android:background="#F44336"
        android:elevation="4dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:text="❌ Kullanıcı bulunamadı!" />

    <!-- Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:padding="8dp">

        <Button
            android:id="@+id/btnGoToMain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏠 Ana Menü"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginEnd="6dp"
            android:backgroundTint="#9E9E9E"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnGoToRegistration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📝 Kayıt"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#9E9E9E"
            android:elevation="2dp" />

    </LinearLayout>

</LinearLayout>

